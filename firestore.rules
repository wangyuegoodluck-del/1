rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: customers
    // Document ID: auto-generated or customer name slug
    // Fields:
    //   - id: string (required)
    //   - name: string (required, min 2 chars) - Official company name
    //   - taxId: string (required) - Unified Social Credit Code
    //   - address: string (optional)
    //   - phone: string (optional)
    //   - bank: string (optional)
    //   - account: string (optional)
    //   - lastUsed: string (required, ISO 8601)
    //   - uid: string (required) - Owner UID
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidCustomer(data) {
      return data.name is string && data.name.size() >= 2 && data.name.size() < 200 &&
             data.taxId is string && data.taxId.size() >= 9 && data.taxId.size() < 50 &&
             (!('address' in data) || (data.address is string && data.address.size() < 500)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 50)) &&
             (!('bank' in data) || (data.bank is string && data.bank.size() < 200)) &&
             (!('account' in data) || (data.account is string && data.account.size() < 100)) &&
             data.lastUsed is string &&
             data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /customers/{customerId} {
      // Users can only see their own customers (supporting both field names for compatibility)
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.uid == request.auth.uid);
      
      // Users can create their own customers
      allow create: if isAuthenticated() && 
                      (request.resource.data.userId == request.auth.uid || request.resource.data.uid == request.auth.uid);
      
      // Users can update their own customers
      allow update: if isAuthenticated() && 
                      (resource.data.userId == request.auth.uid || resource.data.uid == request.auth.uid);
      
      // Users can delete their own customers
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.uid == request.auth.uid);
    }

    match /products/{productId} {
      // Products are publicly readable if active
      allow read: if resource.data.isActive == true;
      // Writing to products requires admin (handled by a separate admin role if needed, 
      // but for now let's allow read for active products).
      // If we want to support any authenticated user for reading (more secure):
      // allow read: if isAuthenticated() && resource.data.isActive == true;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
