rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 默认拒绝所有访问
    match /{document=**} {
      allow read, write: if false;
    }

    // ==================== 辅助函数 ====================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 获取用户数据（用于鉴权）
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      // 增强逻辑：首先检查是否是硬编码管理员邮箱
      if (isSignedIn() && request.auth.token.email == 'admin@fairino.com') {
        return true;
      }
      // 其次检查数据库记录中的 isAdmin 字段
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().isAdmin == true;
    }

    function isApproved() {
      return isSignedIn() && (getUserData().approved == true || isAdmin());
    }

    // ==================== 规则 ====================

    // 用户配置
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    request.resource.data.isAdmin == false && 
                    request.resource.data.approved == false;
      
      allow update: if isAdmin() || (
        isOwner(userId) && 
        request.resource.data.isAdmin == resource.data.isAdmin && 
        request.resource.data.approved == resource.data.approved
      );
    }

    // 客户数据 - 仅限已审批用户
    match /customers/{customerId} {
      allow read: if isApproved() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isApproved() && (
        (request.resource.data.userId == request.auth.uid) || isAdmin()
      );
    }

    // 产品目录 - 仅限已审批用户读取，管理员写入
    match /products/{productId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // 测试连接文档
    match /test/connection {
      allow read: if true;
    }
  }
}
